# OpenAI API key used by the Flask backend.
# Put your real key only in backend/.env, never in this example file.
# Recommended testing value here: keep this placeholder.
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model used for document extraction.
# Available examples: gpt-5-mini, gpt-5-nano, gpt-4.1-mini.
# Recommended testing value: gpt-5-mini for balanced cost and accuracy.
OPENAI_MODEL=gpt-5-mini

# Prompt style used for extraction.
# Available options: compact, normal.
# compact is shorter and cheaper; normal may help accuracy but costs more.
OPENAI_PROMPT_MODE=compact

# Maximum upload size accepted by Flask, in megabytes.
# Recommended testing value: 10.
# Higher values allow larger PDFs/images but can slow processing.
MAX_UPLOAD_MB=10

# Maximum number of PDF pages rendered and sent to OpenAI.
# Recommended testing value: 1; increase only when documents need more pages.
# Higher values increase input tokens, cost, and processing time.
MAX_PDF_PAGES=1

# PDF render quality in DPI before image preprocessing.
# Recommended testing range: 150-200; use 250-300 only for small text.
# Higher DPI improves readability but increases image size and cost.
PDF_RENDER_DPI=200

# Image preprocessing mode before sending to OpenAI.
# Available options: auto, original_color, enhanced_color, grayscale, adaptive_threshold.
# Recommended testing value: auto.
IMAGE_PREPROCESS_MODE=auto

# Whether automatic document cropping is enabled.
# Available options: true, false.
# true can reduce background; false preserves the original full image.
AUTO_CROP_RECEIPT=true

# Scanner-style crop behavior.
# Available options: conservative, aggressive, disabled.
# Recommended testing value: conservative to avoid cutting off important fields.
SCANNER_CROP_MODE=conservative

# Minimum confidence required before applying a crop.
# Available range: 0.0-1.0; recommended testing value: 0.85.
# Higher values reject more crops and preserve more content.
MIN_CROP_CONFIDENCE=0.85

# Padding added around detected document crop.
# Available range: 0.00-0.20; recommended testing value: 0.08.
# Higher values keep more page edges but may include more background.
CROP_PADDING_RATIO=0.08

# Minimum crop area relative to the original image.
# Available range: 0.0-1.0; recommended testing value: 0.50.
# Higher values reject small inner-table crops.
CROP_MIN_AREA_RATIO=0.50

# Extra safety checks to avoid tight or risky crops.
# Available options: true, false.
# Recommended testing value: true.
CONSERVATIVE_CROP=true

# Whether safe four-corner perspective correction is allowed.
# Available options: true, false.
# true can straighten tilted documents; false avoids warping risk.
ENABLE_PERSPECTIVE_CORRECTION=true

# Maximum image size before sending to OpenAI.
# The longest side is resized to this value.
# Recommended presets: 1200 for testing, 1600 for better small-text accuracy.
MAX_IMAGE_DIMENSION=1200

# JPEG quality for the processed image sent to OpenAI.
# Available range: 1-100.
# Recommended presets: 80 for testing, 85 for better quality.
IMAGE_JPEG_QUALITY=70

# Whether to return before/after image previews to the frontend.
# Available options: true, false.
# true helps debugging; false reduces API response size.
RETURN_IMAGE_PREVIEW=true

# Whether to include preprocessing debug scores in API metadata.
# Available options: true, false.
# true helps tuning; false is cleaner for production.
SHOW_PREPROCESS_DEBUG=true

# Flask runtime environment.
# Available options: development, production.
# development enables debug behavior; use production for deployment.
FLASK_ENV=development

# Input token price for the selected OpenAI model.
# Value is cost per 1M input tokens in USD.
# Update this only when model pricing changes.
OPENAI_INPUT_COST_PER_1M=0.75

# Output token price for the selected OpenAI model.
# Value is cost per 1M output tokens in USD.
# Update this only when model pricing changes.
OPENAI_OUTPUT_COST_PER_1M=4.50

# Exchange rate used to estimate cost in Malaysian Ringgit.
# Recommended testing value: update manually when exchange rate changes.
# This affects estimated MYR only, not actual OpenAI billing.
USD_TO_MYR_RATE=4.70
